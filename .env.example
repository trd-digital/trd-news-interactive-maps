# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# Loaded automatically by trd_common (see trd_common/geocode.py).

# Google Maps Geocoding API key (used by trd_common.geocode.Geocoder)
GOOGLE_MAPS_API_KEY=

# Mapbox access token (used for map tiles in the notebooks)
MAPBOX_ACCESS_TOKEN=
